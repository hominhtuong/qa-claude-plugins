# Copy to `.env` and fill real values. `.env` is git-ignored — never commit secrets.
# Precedence (high → low): -D system property > OS env var > .env > configs/<env>.properties

# Test account (already onboarded → GoToHome just logs in).
LOGIN_USERNAME=
LOGIN_PASSWORD=

# Device / driver (override per machine). See configs/staging.properties for the rest.
# APPIUM_URL=http://127.0.0.1:4723/
# PLATFORM=android            # android | ios
# DEVICE_NAME=emulator-5554
# APP_PACKAGE=
# APP_ACTIVITY=
# UDID=
