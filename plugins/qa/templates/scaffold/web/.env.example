# Copy to `.env` and fill real values. `.env` is git-ignored — never commit secrets.
# Precedence (high → low): -D system property > OS env var > .env > configs/<env>.properties

# Default valid account (already onboarded → GoToHome just logs in).
LOGIN_USERNAME=
LOGIN_PASSWORD=

# Optional overrides
# BASE_URL=__BASE_URL__
BROWSER=chromium                # chromium | firefox | webkit
# Default = fast/headless (CI + new machines). To WATCH, use `make <target> HEADED=1` instead of editing this.
HEADLESS=true                   # true | false
SLOWMO=0                        # ms delay per action when debugging (headed)
PAUSE_AFTER_TEST=0              # ms pause at end of EACH test (debug, headed). 0 = off
