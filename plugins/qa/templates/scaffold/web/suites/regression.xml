<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  REGRESSION suite, PARALLEL (faster, flakier). Runs @Test(groups = "regression") across
  __PKG__.regressions.<feature>. Run: `make regression-fast`.
  Prefer the serial variant (`make regression`) for a clean report / single browser.
-->
<suite name="Regression" verbose="1" parallel="methods" thread-count="3">
    <listeners>
        <listener class-name="__PKG__.base.RetryListener"/>
        <listener class-name="__PKG__.base.SitemapListener"/>
        <listener class-name="__PKG__.base.ReportListener"/>
    </listeners>
    <test name="Regression - all features">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="__PKG__.regressions.*"/>
        </packages>
    </test>
</suite>
