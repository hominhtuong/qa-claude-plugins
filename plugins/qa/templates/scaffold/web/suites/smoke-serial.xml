<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  SMOKE suite, SERIAL (thread-count=1) — ONE browser for the whole run, no flicker.
  The safe default for a clean, green report. Used by `make smoke`.
  Parallel variant (faster, flakier): `make smoke-fast`.
-->
<suite name="Smoke (serial)" verbose="1" thread-count="1">
    <listeners>
        <listener class-name="__PKG__.base.RetryListener"/>
        <listener class-name="__PKG__.base.SitemapListener"/>
        <listener class-name="__PKG__.base.ReportListener"/>
    </listeners>
    <test name="Smoke - all features (serial)">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="__PKG__.smoke.*"/>
        </packages>
    </test>
</suite>
