# ─────────────────────────────────────────────────────────────
# qa plugin — secrets. The `setup` skill installs this as:
#     <project>/.claude/qa-claude/.plugin.env          (your real values — git-ignored, NEVER overwritten)
#     <project>/.claude/qa-claude/.plugin.env.example  (this reference — refreshed on plugin update)
# Named `.plugin.env` (not `.env`) so it never collides with the project's own ./.env.
# Everything here is OPTIONAL & independent: leave ENABLE_*=false to skip.
# Report is ALWAYS written locally regardless — these only add notify / cloud share.
# Use YOUR OWN accounts (no shared/plugin credentials). Read by scripts/*.py.
#
# NOTIFY (pick AT MOST ONE): Lark  OR  generic webhook (Slack/Teams/Telegram/Discord)
# UPLOAD (pick AT MOST ONE): Cloudflare R2  OR  S3-compatible (AWS/CMC/MinIO)
# LARK APP   : app id/secret for Bitable (/qa:log-bug) + Doc reading — verified by /qa:auth-lark
# ─────────────────────────────────────────────────────────────

# ===== (OPTIONAL · LARK APP) OPEN-API APP — Bitable / Drive / Docs =====
# Credentials of YOUR Lark custom app (Developer Console → Credentials & Basic Info).
# Used by /qa:log-bug (create bug records on a Bitable board) and Lark doc readers.
# Run `/qa:auth-lark` after filling these: it authenticates, probes what the app id can
# do, and warns if a command needs a permission the app is missing. Default = request
# FULL capability (Bitable read+write, Drive read+upload, Docx/Wiki read).
# Grant the matching scopes in the Developer Console → Permissions & Scopes, then publish.
ENABLE_LARK_APP=false
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=your_app_secret
LARK_DOMAIN=https://open.larksuite.com    # Feishu (China): https://open.feishu.cn
# Auto-managed by /qa:auth-lark — resolved capabilities (do not hand-edit):
LARK_APP_CAPABILITIES=

# ===== (OPTIONAL · NOTIFY-A) LARK BOT — Custom Bot Webhook =====
# Post a result card to YOUR Lark group. No extra deps (python stdlib only).
ENABLE_LARK_NOTIFY=false
LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/xxxxxxxx
LARK_WEBHOOK_SECRET=your_sign_secret
LARK_PLATFORM=My QA Bot
LARK_USER=QA Team

# ===== (OPTIONAL · NOTIFY-B) GENERIC WEBHOOK — Slack/Teams/Telegram/Discord =====
# Alternative to Lark. No extra deps. NOTIFY_PROVIDER picks the payload shape.
#   slack|discord|teams|generic -> set NOTIFY_WEBHOOK_URL
#   telegram                    -> set NOTIFY_TELEGRAM_TOKEN + NOTIFY_TELEGRAM_CHAT_ID
ENABLE_NOTIFY_WEBHOOK=false
NOTIFY_PROVIDER=slack
NOTIFY_WEBHOOK_URL=
NOTIFY_TELEGRAM_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_PLATFORM=My QA Bot
NOTIFY_USER=QA Team

# ===== (OPTIONAL · UPLOAD-A) CLOUDFLARE R2 — share report via URL =====
# Push the report to YOUR R2 bucket. Needs wrangler CLI (setup/doctor auto-installs).
ENABLE_CF_PUSH=false
CF_ACCOUNT_ID=your_account_id
CF_API_TOKEN=your_api_token_r2_edit
CF_R2_BUCKET=reports
CF_R2_DOMAIN=https://your-r2-custom-domain
CF_R2_PREFIX=auto

# ===== (OPTIONAL · UPLOAD-B) S3-COMPATIBLE — AWS S3 / CMC Cloud / MinIO =====
# Alternative to R2. Needs the `aws` CLI (brew/winget/apt install awscli).
# Leave S3_ENDPOINT blank for real AWS; set it for CMC/MinIO/other.
ENABLE_S3_PUSH=false
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=reports
S3_REGION=ap-southeast-1
S3_ENDPOINT=
S3_PREFIX=auto
S3_PUBLIC_BASE=https://your-public-base
