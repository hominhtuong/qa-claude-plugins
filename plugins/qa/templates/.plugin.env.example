# ─────────────────────────────────────────────────────────────
# qa plugin — secrets. The `setup` skill installs this as:
#     <project>/.claude/qa-claude/.plugin.env          (your real values — git-ignored, NEVER overwritten)
#     <project>/.claude/qa-claude/.plugin.env.example  (this reference — refreshed on plugin update)
# Named `.plugin.env` (not `.env`) so it never collides with the project's own ./.env.
# Everything here is OPTIONAL & independent: leave ENABLE_*=false to skip.
# Report is ALWAYS written locally regardless — these only add notify / cloud share.
# Use YOUR OWN accounts (no shared/plugin credentials). Read by scripts/*.py.
#
# NOTIFY (pick AT MOST ONE): Lark  OR  generic webhook (Slack/Teams/Telegram/Discord)
# UPLOAD (pick AT MOST ONE): Cloudflare R2  OR  S3-compatible (AWS/CMC/MinIO)
# LARK APP   : app id/secret for Bitable (/qa:log-bug) + Doc reading — verified by /qa:auth-lark
# ─────────────────────────────────────────────────────────────

# ===== (OPTIONAL · WEB DRIVER) PLAYWRIGHT HEADLESS =====
# Controls whether the bundled Playwright MCP opens a VISIBLE browser window.
#   (unset / false) -> headed  (visible browser — default, easier to watch & screenshot)
#   true            -> headless (no window — for CI / background / faster runs)
# Keyed by ANY variable whose NAME contains "headless" (case-insensitive) — HEADLESS,
# QA_HEADLESS, PW_HEADLESS, PLAYWRIGHT_HEADLESS all work. Resolution order: the main
# project's ./.env first, then here, then defaults to headed. A project that configures
# its own `playwright` MCP server in .mcp.json bypasses this and controls headless itself.
HEADLESS=false

# ===== (OPTIONAL · OUTPUT LANGUAGE) REPORTS & DELIVERABLES =====
# Language for everything the plugin GENERATES FOR THE USER — bug reports, test cases,
# test plans, analysis/summary docs, review findings, and the prose a command prints.
#   Vietnamese  -> deliverables in Vietnamese (with full diacritics)   [default]
#   English     -> deliverables in English
# Value is case-insensitive; missing/empty/unknown -> Vietnamese (never blocks).
# ONLY user-facing OUTPUT follows this. Skill/command definitions, rules/*.md, code,
# identifiers, locators, file/folder names, sitemap ids/routes, git commit & PR messages,
# and any CLAUDE.md stay in English regardless. Full policy: rules/output-language.md.
LANGUAGE=Vietnamese

# ===== (OPTIONAL · LARK APP) OPEN-API APP — Bitable / Drive / Docs =====
# Credentials of YOUR Lark custom app (Developer Console → Credentials & Basic Info).
# Used by /qa:log-bug (create bug records on a Bitable board) and Lark doc readers.
# Run `/qa:auth-lark` after filling these: it authenticates, probes what the app id can
# do, and warns if a command needs a permission the app is missing. Default = request
# FULL capability (Bitable read+write, Drive read+upload, Docx/Wiki read).
# Grant the matching scopes in the Developer Console → Permissions & Scopes, then publish.
# Set ENABLE_LARK_APP=true AND fill REAL app id/secret (the cli_xxx / your_app_secret
# below are placeholders — /qa:auth-lark refuses to call Lark until you replace them).
ENABLE_LARK_APP=false
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=your_app_secret
# Lark Suite (global). For Feishu (China) use: https://open.feishu.cn
LARK_DOMAIN=https://open.larksuite.com

# Token mode for reading Lark docs — TWO ways, both optional, both verified by /qa:auth-lark:
#   tenant (app token) : the DOC must be shared with the APP. Default, no extra setup.
#   user   (UAT)       : the DOC must be visible to YOU. Needs a one-time OAuth login:
#                        run `/qa:auth-lark --login`, approve, then `--login --code <CODE>`.
# LARK_TOKEN_MODE preference: auto (pick whichever mode has more granted read scopes;
#   tie → tenant) | tenant | user. lark_read.py also auto-FALLS BACK to the other mode
#   if the chosen one is denied a given doc.
LARK_TOKEN_MODE=auto
# Auto-managed by /qa:auth-lark — DO NOT hand-edit (secrets; .plugin.env is git-ignored):
LARK_USER_REFRESH_TOKEN=
LARK_READ_MODE=
LARK_APP_CAPABILITIES=
LARK_USER_CAPABILITIES=
# Optional OAuth overrides (only if your app registered a different redirect / scope):
# LARK_REDIRECT_URI must EXACTLY match a Redirect URL registered in the app console
# (Security Settings → Redirect URLs). A mismatch makes Lark return error 20029.
# /qa:auth-lark --login persists the redirect it used here automatically once login works.
# LARK_REDIRECT_URI=http://localhost:8080/callback
# LARK_USER_SCOPE=offline_access docx:document:readonly wiki:wiki:readonly drive:drive:readonly bitable:app:readonly
# Optional: test docx/wiki read scopes against a REAL document you can open (more reliable
# than the throwaway-token probe). /qa:auth-lark --probe-doc <url> overrides this per run.
# LARK_PROBE_DOC=

# ===== (OPTIONAL · TLS) CORPORATE PROXY / SELF-SIGNED CA BUNDLE =====
# Only needed if Lark calls fail with `CERTIFICATE_VERIFY_FAILED: self-signed certificate`
# (a corporate proxy injects a root CA that Python's bundled certs don't trust). Point this
# at a PEM bundle that includes that root CA; the plugin's TLS context will trust it.
#   macOS : pip install certifi; CERT="$(python3 -m certifi)";
#           security find-certificate -a -p /Library/Keychains/System.keychain >> "$CERT";
#           then set SSL_CERT_FILE=$CERT  (path printed by `python3 -m certifi`)
#   Linux : cat /etc/ssl/certs/ca-certificates.crt corp-root.pem > ~/qa-ca-bundle.pem
#   Windows: pip install truststore  (auto-uses the Windows trust store — no file needed)
# Alternative to a file: `pip install truststore` and the plugin uses the OS trust store.
# SSL_CERT_FILE=

# ===== (OPTIONAL · NOTIFY-A) LARK BOT — Custom Bot Webhook =====
# Post a result card to YOUR Lark group. No extra deps (python stdlib only).
ENABLE_LARK_NOTIFY=false
LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/xxxxxxxx
LARK_WEBHOOK_SECRET=your_sign_secret
LARK_PLATFORM=My QA Bot
LARK_USER=QA Team

# ===== (OPTIONAL · NOTIFY-B) GENERIC WEBHOOK — Slack/Teams/Telegram/Discord =====
# Alternative to Lark. No extra deps. NOTIFY_PROVIDER picks the payload shape.
#   slack|discord|teams|generic -> set NOTIFY_WEBHOOK_URL
#   telegram                    -> set NOTIFY_TELEGRAM_TOKEN + NOTIFY_TELEGRAM_CHAT_ID
ENABLE_NOTIFY_WEBHOOK=false
NOTIFY_PROVIDER=slack
NOTIFY_WEBHOOK_URL=
NOTIFY_TELEGRAM_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_PLATFORM=My QA Bot
NOTIFY_USER=QA Team

# ===== (OPTIONAL · UPLOAD-A) CLOUDFLARE R2 — share report via URL =====
# Push the report to YOUR R2 bucket. Needs wrangler CLI (setup/doctor auto-installs).
ENABLE_CF_PUSH=false
CF_ACCOUNT_ID=your_account_id
CF_API_TOKEN=your_api_token_r2_edit
CF_R2_BUCKET=reports
CF_R2_DOMAIN=https://your-r2-custom-domain
CF_R2_PREFIX=auto

# ===== (OPTIONAL · UPLOAD-B) S3-COMPATIBLE — AWS S3 / CMC Cloud / MinIO =====
# Alternative to R2. Needs the `aws` CLI (brew/winget/apt install awscli).
# Leave S3_ENDPOINT blank for real AWS; set it for CMC/MinIO/other.
ENABLE_S3_PUSH=false
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=reports
S3_REGION=ap-southeast-1
S3_ENDPOINT=
S3_PREFIX=auto
S3_PUBLIC_BASE=https://your-public-base
